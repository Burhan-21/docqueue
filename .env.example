# ============================================================
# DocQueue SaaS — Environment Variables Template
# cp .env.example .env  →  then fill in real values
# NEVER commit .env to Git (it's already in .gitignore)
# ============================================================

# ===== Database (MySQL) =====
DB_USER=docqueue
DB_PASS=change_me_strong_password
MYSQL_ROOT_PASS=change_me_root_password

# ===== JWT (generate with: openssl rand -base64 64) =====
JWT_SECRET=your-256-bit-base64-encoded-secret-here

# ===== Admin Seed Account =====
# First user seeded on startup — change BEFORE first run in production
ADMIN_EMAIL=admin@docqueue.in
ADMIN_PASSWORD=Admin@1234

# ===== Redis =====
# If you add a Redis password, set it here:
# REDIS_PASS=your_redis_password

# ===== Twilio SMS =====
# Leave blank to disable SMS — email notifications will still work
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_twilio_auth_token
TWILIO_FROM=+1234567890

# ===== Email (SMTP / Gmail App Password) =====
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your_app_password

# ===== Frontend / CORS =====
FRONTEND_URL=https://app.yourdomain.com

# ===== Google reCAPTCHA (optional) =====
# Leave blank (or keep test key) to bypass CAPTCHA in dev
# For production: register at https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET=6LeIxAcTAAAAAGG-vFI1TnFTxWfnC0CFU9onvZ17
