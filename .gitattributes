# DocQueue — Git line ending normalization
# Ensures consistent LF line endings on all platforms

* text=auto eol=lf

# Force LF for code files
*.java    text eol=lf
*.js      text eol=lf
*.jsx     text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.css     text eol=lf
*.html    text eol=lf
*.json    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.xml     text eol=lf
*.sql     text eol=lf
*.md      text eol=lf
*.sh      text eol=lf
Dockerfile text eol=lf
*.conf    text eol=lf

# Keep binary files untouched
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.svg     binary
*.jar     binary
*.zip     binary
